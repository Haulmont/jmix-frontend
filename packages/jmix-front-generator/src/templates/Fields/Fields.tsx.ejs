<% if (attributes.length > 0) { %>
  import {Field} from '@haulmont/jmix-react-ui';
<% } %>
      
const ENTITY_NAME = '<%= entity.name %>';

interface <%= fieldsComponentName %>Props {
      relationOptions: any;
      entityId?: string;
}

const <%= fieldsComponentName %> = ({

}: <%= fieldsComponentName %>Props) => {
    return (
        <% attributes.forEach(attr => { %>
            <Field entityName={ENTITY_NAME}
                   propertyName="<%= attr.name %>"
  
              <% if (readOnlyFields.includes(attr.name)) { %>
                   disabled={true}
              <% } else if (attr.name === locals.stringIdName) { %>
                   disabled={!isNewEntity(entityId)}
              <% } %>
  
              <% if (Object.keys(associations).includes(attr.name)) { %>
                   associationOptions={relationOptions?.get('<%= dollarsToUnderscores(associations[attr.name].name) %>')}
              <% } %>
  
                    formItemProps={{
                    style: {marginBottom: "12px"},
              <% if (attr.mandatory) { -%>
                    rules: [{required: true}],
              <% } -%>
              <% if (attr.type && attr.type.fqn === 'java.lang.Boolean') { -%>
                    valuePropName: "checked",
              <% } -%>
              }}
            /> <%# end Field %>
          <% }) %>
    )
}